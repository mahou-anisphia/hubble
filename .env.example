# ============================================================
# Hubble — Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your values.
# No variable here is strictly required — Hubble is designed
# to degrade gracefully based on what is available.
# ============================================================


# ------------------------------------------------------------
# OPERATIONAL — Infrastructure Services
# ------------------------------------------------------------
# Redis: Rate-limiting & caching layer.
#   → If unset or unreachable, Hubble runs cache-free.
#     Expect potential 429s under high request volume.
#
REDIS_ENDPOINT=100.79.145.19
REDIS_PORT=6379

# Kafka: Event streaming / push pipeline.
#   → If unset or unreachable, Hubble operates as REST API only.
#     Push-based features (Quasar integration, event emission)
#     will be silently skipped.
#
KAFKA_ENDPOINT=100.79.145.19
KAFKA_PORT=9092


# ------------------------------------------------------------
# API MODULES — External Data Sources
# ------------------------------------------------------------
# Each module is independently scoped.
# A missing or invalid key disables that module only —
# other modules continue operating normally.

# OpenWeather — Weather data
#
VITE_OPENWEATHER_API_KEY=your-openweather-api-key
VITE_OPENWEATHER_API_ENDPOINT=api.openweathermap.org

# AirVisual (IQAir) — Air quality data
#
AQAIR_API_KEY=your-aqair-api-key
AQAIR_API_ENDPOINT=api.airvisual.com